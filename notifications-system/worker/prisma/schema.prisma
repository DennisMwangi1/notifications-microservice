generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  esm      = "true"
}

datasource db {
  provider = "postgresql"
}

model notification_logs {
  notification_id String       @id @db.Uuid
  user_id         String       @db.Uuid
  template_id     String       @db.VarChar(100)
  channel         channel_enum
  status          status_enum? @default(PENDING)
  metadata        Json?
  provider_ref    String?      @db.VarChar(255)
  sent_at         DateTime?    @db.Timestamp(6)
  error_details   String?
}

model templates {
  template_id  String       @db.VarChar(100)
  version      Int
  channel_type channel_enum
  subject_line String?      @db.VarChar(255)
  content_body String
  locale       String?      @default("en") @db.VarChar(10)
  is_active    Boolean?     @default(true)
  created_at        DateTime?    @default(now()) @db.Timestamp(6)
  tenant_id         String?      @db.Uuid
  event_type        String?      @db.VarChar(100)
  target_ws_channel String?      @db.VarChar(100)

  @@id([template_id, version])
}


enum channel_enum {
  EMAIL
  SMS
  PUSH
}

enum status_enum {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum in_app_status {
  UNREAD
  READ
}

model in_app_notifications {
  id             String        @id @default(uuid()) @db.Uuid
  user_id        String        @db.Uuid
  project_source String
  type           String
  title          String
  body           String
  status         in_app_status @default(UNREAD)
  created_at     DateTime      @default(now()) @db.Timestamp(6)
}

model tenants {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  api_key          String   @unique
  allowed_channels String[] // e.g. ["ecommerce_store", "support_chat"]
  created_at       DateTime @default(now()) @db.Timestamp(6)
  is_active        Boolean  @default(true)
}
